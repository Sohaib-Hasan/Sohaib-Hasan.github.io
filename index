<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sohaib Hasan</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --board: #1c2b26;
    --board-edge: #16211d;
    --chalk: #f2ede1;
    --chalk-dim: #b9c2bb;
    --accent: #e8b04b;
  }
  *{box-sizing:border-box;}
  html,body{height:100%;}
  body{
    margin:0;
    background: radial-gradient(ellipse at 50% 40%, var(--board) 0%, var(--board-edge) 100%);
    color: var(--chalk);
    font-family: 'Inter', sans-serif;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
    position:relative;
  }
  svg.doodle{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    opacity:0.16;
    stroke: var(--chalk);
    fill:none;
    stroke-width:1.1;
  }
  .wrap{
    position:relative;
    z-index:1;
    text-align:center;
    padding:2rem;
    max-width:640px;
  }
  .eyebrow{
    font-size:0.72rem;
    letter-spacing:0.22em;
    text-transform:uppercase;
    color:var(--accent);
    margin-bottom:1.1rem;
    font-weight:500;
  }
  h1{
    font-family:'Fraunces', serif;
    font-weight:500;
    font-size:clamp(2.6rem, 7vw, 4.2rem);
    margin:0 0 0.6rem 0;
    letter-spacing:-0.01em;
  }
  .role{
    font-family:'Fraunces', serif;
    font-style:italic;
    font-weight:400;
    font-size:1.15rem;
    color:var(--chalk-dim);
    margin:0 0 2.2rem 0;
  }
  .status{
    display:inline-flex;
    align-items:center;
    gap:0.5rem;
    font-size:0.8rem;
    color:var(--chalk-dim);
    letter-spacing:0.03em;
    border-top:1px solid rgba(242,237,225,0.18);
    padding-top:1.4rem;
  }
  .dot{
    width:6px;height:6px;border-radius:50%;
    background:var(--accent);
    box-shadow:0 0 8px var(--accent);
  }
</style>
</head>
<body>

<svg class="doodle" viewBox="0 0 1000 600" preserveAspectRatio="xMidYMid slice">
  <path d="M -50 480 Q 250 100, 500 320 T 1050 200" />
  <line x1="80" y1="60" x2="80" y2="560" />
  <line x1="40" y1="500" x2="960" y2="500" />
  <circle cx="80" cy="500" r="220" stroke-dasharray="3 6" />
  <path d="M 600 480 C 700 380, 700 250, 850 150" />
</svg>

<div class="wrap">
  <div class="eyebrow">Mathematics &middot; AI Reasoning &middot; PlotLab</div>
  <h1>Sohaib Hasan</h1>
  <p class="role">Mathematics Lecturer &amp; Head of Department</p>
  <div class="status"><span class="dot"></span> Full site launching soon</div>
</div>

</body>
</html>
